rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Family chat: the room id is a shared secret (never written into the site code).
    // Messages are create-only and size-capped; nothing can be edited or deleted from the client.
    match /rooms/{room}/messages/{msg} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['n', 't', 'ts'])
        && request.resource.data.n is string
        && request.resource.data.n.size() >= 1 && request.resource.data.n.size() <= 30
        && request.resource.data.t is string
        && request.resource.data.t.size() >= 1 && request.resource.data.t.size() <= 500
        && request.resource.data.ts == request.time;
      allow update, delete: if false;
    }
  }
}
